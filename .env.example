# Source — RTSP stream from IP camera (e.g. Hikvision, Dahua, generic ONVIF)
RTSP_URL=rtsp://user:pass@CAMERA_IP:554/stream

# Telegram bot for alerts (get token from @BotFather, chat_id via getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Inference device: mps (Apple Silicon), cuda, or cpu
DEVICE=mps

# Dwell-time alert: a person must remain inside the polygon zone this long before alerting
DWELL_THRESHOLD_SECONDS=10

# Per-track-id cooldown after a dwell alert fires (prevents re-alert on same person)
ALERT_COOLDOWN_SECONDS=30

# Which COCO class to track inside the zone
WATCH_CLASS=person

# Blur faces in the rendered output (privacy in demo recordings)
ENABLE_FACE_BLUR=true

# Polygon = centered rectangle inset by this fraction of frame size on each side
POLYGON_PADDING_RATIO=0.25
